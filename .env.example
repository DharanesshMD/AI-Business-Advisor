# =============================================================================
# AI Business Advisor - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys

# -----------------------------------------------------------------------------
# Required API Keys
# -----------------------------------------------------------------------------

# NVIDIA API Key (from build.nvidia.com)
# Required for Llama 3.1 Nemotron 70B model access
NVIDIA_API_KEY=your_nvidia_api_key_here

# Tavily API Key (from tavily.com)
# Required for web search functionality
TAVILY_API_KEY=your_tavily_api_key_here

# -----------------------------------------------------------------------------
# Model Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------

# MODEL_NAME=nvidia/llama-3.1-nemotron-70b-instruct
# MODEL_TEMPERATURE=0.2
# MODEL_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Application Settings (Optional - defaults shown)
# -----------------------------------------------------------------------------

# APP_NAME=AI Business Advisor
# APP_VERSION=1.0.0-mvp
# DEBUG=false

# -----------------------------------------------------------------------------
# Server Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------

# HOST=0.0.0.0
# PORT=8000

# -----------------------------------------------------------------------------
# Logging Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------
# LOG_LEVEL=DEBUG        # Options: DEBUG, INFO, WARNING, ERROR
# Logs are saved to /logs directory:
# - advisor_YYYYMMDD.log   (Human-readable text logs)
# - advisor_YYYYMMDD.jsonl (Structured JSON logs for analysis)
